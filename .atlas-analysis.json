  "keyFeatures": [
    "Iterate 800,000 entities at 60 FPS with cache-friendly archetype storage",
    "Entity relationships as first-class citizens with pair support",
    "Type-safe Luau API with zero dependencies",
    "Query system with filtering, caching, and wildcard support",
    "Lifecycle hooks and signals for component changes",
    "Component preregistration and entity recycling"
  ],
